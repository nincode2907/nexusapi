// NexusAPI - AI Proxy Gateway
// Prisma Schema for Token-Economy System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// User: Core account model
// ─────────────────────────────────────────────
enum UserRole {
  USER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  emailVerified DateTime? @map("email_verified")
  image        String?
  role         UserRole @default(USER)
  totalCredit  Float    @default(0) @map("total_credit")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  accounts     Account[]
  sessions     Session[]
  apiKeys      ApiKey[]
  transactions Transaction[]
  usageLogs    UsageLog[]

  @@map("users")
}

// ─────────────────────────────────────────────
// ApiKey: Per-user API keys for proxy access
// ─────────────────────────────────────────────
enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

model ApiKey {
  id        String       @id @default(cuid())
  hashedKey String       @unique @map("hashed_key")
  maskedKey String       @map("masked_key")
  name      String?      // Optional label, e.g. "Production Key"
  userId    String       @map("user_id")
  status    ApiKeyStatus @default(ACTIVE)
  lastUsed  DateTime?    @map("last_used")
  createdAt DateTime     @default(now()) @map("created_at")

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageLogs UsageLog[]

  @@index([hashedKey])
  @@index([userId])
  @@map("api_keys")
}

// ─────────────────────────────────────────────
// Transaction: VND top-up & affiliate credits
// ─────────────────────────────────────────────
enum TransactionType {
  TOPUP
  AFFILIATE
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

model Transaction {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  amountVnd   Float             @map("amount_vnd")
  creditAdded Float             @map("credit_added")
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  refCode     String?           @map("ref_code")
  metadata    Json?             // Payment gateway response, notes, etc.
  createdAt   DateTime          @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refCode])
  @@map("transactions")
}

// ─────────────────────────────────────────────
// UsageLog: Per-request token usage tracking
// ─────────────────────────────────────────────
model UsageLog {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  apiKeyId         String   @map("api_key_id")
  modelName        String   @map("model_name")
  promptTokens     Int      @map("prompt_tokens")
  completionTokens Int      @map("completion_tokens")
  cachedTokens     Int      @default(0) @map("cached_tokens")
  totalCostCredit  Float    @map("total_cost_credit")
  creditSaved      Float    @default(0) @map("credit_saved")
  duration         Int?     // Response time in ms
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey ApiKey  @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([apiKeyId])
  @@index([modelName])
  @@index([createdAt])
  @@map("usage_logs")
}

// ─────────────────────────────────────────────
// ModelPricing: Per-model token pricing
// ─────────────────────────────────────────────
model ModelPricing {
  id                  String   @id @default(cuid())
  modelId             String   @unique @map("model_id")     // Bắt buộc giữ: Mã API thực tế (VD: gpt-4o-mini)
  displayName         String?  @map("display_name")         // Bắt buộc giữ: Tên hiển thị UI (VD: GPT-4o Mini)
  
  // -- Giá cả --
  priceInPerToken     Float    @map("price_in_per_token")
  priceCachedPerToken Float?   @default(0) @map("price_cached_per_token")
  priceOutPerToken    Float    @map("price_out_per_token")
  minCreditRequired   Float    @default(0) @map("min_credit_required")
  
  // -- Thông số kỹ thuật (MỚI) --
  provider            String   @default("OpenAI")
  description         String?
  contextWindow       Int      @default(0) @map("context_window")
  maxOutputTokens     Int      @default(0) @map("max_output_tokens")
  knowledgeCutoff     String?  @map("knowledge_cutoff")
  features            String[] // PostgreSQL string array
  badge               String?  // MỚI: Thẻ tag tùy chỉnh. VD: "MÔ HÌNH MỚI", "HOT", "-50% OFF"
  badgeColor          String?  // MỚI: Màu của thẻ. VD: "purple", "red", "green"
  usageCount          Int      @default(0) // MỚI: Đếm lượt dùng để làm tính năng Sort "Trending"
  
  // -- Trạng thái hệ thống --
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("model_pricing")
}

// ─────────────────────────────────────────────
// NextAuth / Auth.js Models
// ─────────────────────────────────────────────

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// NexusAPI - AI Proxy Gateway
// Prisma Schema for Token-Economy System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// User: Core account model
// ─────────────────────────────────────────────
enum UserRole {
  USER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  emailVerified DateTime? @map("email_verified")
  image        String?
  role         UserRole @default(USER)
  totalCredit  Float    @default(0) @map("total_credit")
  totalDeposit Float    @default(0) @map("total_deposit")
  totalSpent   Float    @default(0) @map("total_spent")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  accounts     Account[]
  sessions     Session[]
  apiKeys      ApiKey[]
  transactions Transaction[]
  usageLogs    UsageLog[]
  userGiftCodes UserGiftCode[]
  creditLedgers CreditLedger[]

  @@map("users")
}

// ─────────────────────────────────────────────
// ApiKey: Per-user API keys for proxy access
// ─────────────────────────────────────────────
enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

model ApiKey {
  id        String       @id @default(cuid())
  hashedKey String       @unique @map("hashed_key")
  maskedKey String       @map("masked_key")
  name      String?      // Optional label, e.g. "Production Key"
  userId    String       @map("user_id")
  status    ApiKeyStatus @default(ACTIVE)
  lastUsed  DateTime?    @map("last_used")
  createdAt DateTime     @default(now()) @map("created_at")

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageLogs UsageLog[]

  @@index([userId])
  @@map("api_keys")
}

// ─────────────────────────────────────────────
// Transaction: VND top-up & affiliate credits
// ─────────────────────────────────────────────
enum TransactionType {
  TOPUP
  AFFILIATE
  GIFT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

// ── BẢNG LƯU MÃ QUÀ TẶNG ──
model GiftCode {
  id           String    @id @default(cuid())
  code         String    @unique @map("code") // VD: NEXUS2026 (Ép In hoa)
  creditReward Float     @map("credit_reward") // Số điểm tặng (VD: 20000)
  
  maxUses      Int       @default(1) @map("max_uses") // Giới hạn số người nhập (VD: 100)
  usedCount    Int       @default(0) @map("used_count") // Đã có bao nhiêu người nhập
  
  expiresAt    DateTime? @map("expires_at") // Ngày hết hạn (Tùy chọn)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")

  redeems      UserGiftCode[]

  @@map("gift_codes")
}

model UserGiftCode {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  giftCodeId   String   @map("gift_code_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  giftCode     GiftCode @relation(fields: [giftCodeId], references: [id], onDelete: Cascade)

  // 🚨 KHÓA CHỐNG SPAM LỚP 1: Một User ID chỉ được ghép cặp với 1 GiftCode ID ĐÚNG 1 LẦN
  @@unique([userId, giftCodeId]) 
  
  @@map("user_gift_codes")
}

model Transaction {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  amountVnd   Float             @map("amount_vnd")
  creditAdded Float             @map("credit_added")
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  refCode     String?           @map("ref_code")
  metadata    Json?             // Payment gateway response, notes, etc.
  createdAt   DateTime          @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refCode])
  @@map("transactions")
}

// ─────────────────────────────────────────────
// UsageLog: Per-request token usage tracking
// ─────────────────────────────────────────────
model UsageLog {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  apiKeyId         String   @map("api_key_id")
  modelName        String   @map("model_name")
  promptTokens     Int      @map("prompt_tokens")
  completionTokens Int      @map("completion_tokens")
  cachedTokens     Int      @default(0) @map("cached_tokens")
  totalCostCredit  Float    @map("total_cost_credit")
  creditSaved      Float    @default(0) @map("credit_saved")
  duration         Int?     // Response time in ms
  statusCode       Int      @default(200) @map("status_code")
  errorMessage     String?  @db.Text @map("error_message")
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey ApiKey  @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([apiKeyId])
  @@index([modelName])

  @@map("usage_logs")
}

enum LedgerType {
  DEPOSIT       // Khách nạp tiền (Từ Transaction)
  USAGE         // Khách xài API (Từ UsageLog)
  PROMO         // Nhận từ GiftCode
  REFUND        // Hoàn tiền do lỗi
  SYSTEM        // Admin can thiệp tay
}

model CreditLedger {
  id            String      @id @default(cuid())
  userId        String      @map("user_id")
  amount        Float       // Số credit thay đổi (+ là cộng, - là trừ)
  balanceAfter  Float       @map("balance_after") // Số dư ví NGAY SAU KHI giao dịch (Traceback)
  type          LedgerType
  description   String?     // VD: "Nạp tiền VietQR", "Gọi GPT-4o", "Nhập mã NEXUS2026"
  referenceId   String?     @map("reference_id") // ID của Transaction/UsageLog/GiftCode liên quan
  createdAt     DateTime    @default(now()) @map("created_at")

  // Relations
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("credit_ledger")
}

// ─────────────────────────────────────────────
// ModelPricing: Per-model token pricing
// ─────────────────────────────────────────────
model ModelPricing {
  id                  String   @id @default(cuid())
  modelId             String   @unique @map("model_id")     // Bắt buộc giữ: Mã API thực tế (VD: gpt-4o-mini)
  displayName         String?  @map("display_name")         // Bắt buộc giữ: Tên hiển thị UI (VD: GPT-4o Mini)
  
  // -- Giá cả --
  costInPerToken      Float?   @default(0) @map("cost_in_per_token")  // Giá gốc sếp mua của Hãng
  costOutPerToken     Float?   @default(0) @map("cost_out_per_token") // Giá gốc sếp mua của Hãng
  priceInPerToken     Float    @map("price_in_per_token")
  priceCachedPerToken Float?   @default(0) @map("price_cached_per_token")
  priceOutPerToken    Float    @map("price_out_per_token")
  minCreditRequired   Float    @default(0) @map("min_credit_required")
  
  // -- Thông số kỹ thuật (MỚI) --
  provider            String   @default("OpenAI")
  description         String?
  contextWindow       Int      @default(0) @map("context_window")
  maxOutputTokens     Int      @default(0) @map("max_output_tokens")
  knowledgeCutoff     String?  @map("knowledge_cutoff")
  features            String[] // PostgreSQL string array
  badge               String?  // MỚI: Thẻ tag tùy chỉnh. VD: "MÔ HÌNH MỚI", "HOT", "-50% OFF"
  badgeColor          String?  // MỚI: Màu của thẻ. VD: "purple", "red", "green"
  usageCount          Int      @default(0) // MỚI: Đếm lượt dùng để làm tính năng Sort "Trending"
  
  // -- Trạng thái hệ thống --
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("model_pricing")
}

// Bảng cấu hình các gói nạp (Sếp có thể thêm bớt trên trang Admin sau này)
model TopupPackage {
  id          String   @id @default(cuid())
  name        String   // VD: "Gói Khởi Nghiệp", "Gói Cá Mập"
  priceVnd    Int      // Số tiền VNĐ khách phải chuyển (VD: 50000)
  creditAmnt  Float    // Số Credit thực nhận (VD: 50000)
  bonusCredit Float    @default(0) // Kích cầu: Tặng thêm 10% (VD: 5000)
  isActive    Boolean  @default(true) // Ẩn/Hiện gói nạp
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────────
// NextAuth / Auth.js Models
// ─────────────────────────────────────────────

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
